exports[`generate: snapshot small fixtures > snapshot: erc/ERC20.ts 1`] = `
"// Generated by abi-to-zod v0.0.0 from ERC20.ts
// Do not edit manually -- regenerate from source.

import { z } from 'zod';

// === Primitive schemas ===

const ADDRESS = z.string().regex(/^0x[0-9a-fA-F]{40}$/).transform((v) => v as \`0x\${string}\`);
const UINT256 = z.string().regex(/^\\d+$/).transform((v) => BigInt(v)).refine((n) => n <= (1n << 256n) - 1n);

// === Function schemas ===

// allowance(address,address)
export const allowanceSchema = z.tuple([
  /* owner: address */ ADDRESS,
  /* spender: address */ ADDRESS,
]);

// approve(address,uint256)
export const approveSchema = z.tuple([
  /* spender: address */ ADDRESS,
  /* value: uint256 */ UINT256,
]);

// balanceOf(address)
export const balanceOfSchema = z.tuple([
  /* account: address */ ADDRESS,
]);

// totalSupply()
export const totalSupplySchema = z.tuple([]);

// transfer(address,uint256)
export const transferSchema = z.tuple([
  /* to: address */ ADDRESS,
  /* value: uint256 */ UINT256,
]);

// transferFrom(address,address,uint256)
export const transferFromSchema = z.tuple([
  /* from: address */ ADDRESS,
  /* to: address */ ADDRESS,
  /* value: uint256 */ UINT256,
]);

// === ABI schema  ===

export const schemas = {
  allowance: allowanceSchema,
  approve: approveSchema,
  balanceOf: balanceOfSchema,
  totalSupply: totalSupplySchema,
  transfer: transferSchema,
  transferFrom: transferFromSchema,
  'allowance(address,address)': allowanceSchema,
  'approve(address,uint256)': approveSchema,
  'balanceOf(address)': balanceOfSchema,
  'totalSupply()': totalSupplySchema,
  'transfer(address,uint256)': transferSchema,
  'transferFrom(address,address,uint256)': transferFromSchema,
} as const;
"
`;
